{
  "name": "forumline",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "TAURI_DIR=desktop-and-mobile-tauri-apps tauri dev",
    "tauri:build": "TAURI_DIR=desktop-and-mobile-tauri-apps tauri build",
    "dev:app": "pnpm --filter forumline-central-services dev",
    "build": "turbo run build",
    "clean": "pnpm -r --if-present run clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2",
    "typescript-eslint": "^8.0.0"
  }
}
