# Terraform state (stored locally, not in repo)
*.tfstate
*.tfstate.backup
.terraform/

# Variable files with secrets
*.auto.tfvars
terraform.tfvars
# prod.tfvars is committed — it only contains non-secret values
# (account_id, developer_email). Secrets use TF_VAR_ env vars.

# Crash logs
crash.log
crash.*.log
